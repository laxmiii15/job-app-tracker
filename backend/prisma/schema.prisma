generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enum or UUID types. Job type and application status are
// stored as plain strings (validated in the app layer / TS enums), and ids are
// uuid strings produced by Prisma's `uuid()` default.

model Application {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  jobTitle    String   @map("job_title")
  jobType     String   @map("job_type")
  status      String   @default("PENDING")
  appliedDate DateTime @map("applied_date")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  stageLogs   StageLog[]

  @@index([status])
  @@index([jobType])
  @@map("applications")
}

// Append-only history of stage (status) transitions for an application.
model StageLog {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStatus    String?     @map("from_status")
  toStatus      String      @map("to_status")
  changedAt     DateTime    @default(now()) @map("changed_at")

  @@index([applicationId])
  @@map("stage_logs")
}
